{
  "expo": {
    "name": "Nutria",
    "slug": "nutria",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF9"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nutria.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Nutria necesita acceso a la cámara para analizar tus comidas con IA."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF9"
      },
      "package": "com.nutria.app",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-secure-store",
      "expo-font",
      [
        "expo-splash-screen",
        { "backgroundColor": "#FAFAF9" }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "nutria"
  }
}
